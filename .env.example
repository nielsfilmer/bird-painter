# Copy to .env and fill in. Never commit .env.
# fal.ai API key — used by the brush (slice 2+). https://fal.ai/dashboard/keys
FAL_KEY=

# Optional knob overrides (defaults in bird_painter/config.py, from PLAN.md):
# BP_PAINT_TTL_SECONDS=10800
# BP_CONFIDENCE_FLOOR=0.6
# Location filter: set BOTH to restrict BirdNET to species plausible at your
# place + season (cuts implausible detections); leave both unset to disable it.
# BP_LATITUDE=52.37          # decimal degrees, -90..90
# BP_LONGITUDE=4.90          # decimal degrees, -180..180
# BP_ANALYSIS_WINDOW_SECONDS=15
# BP_MAX_PAINTS_PER_HOUR=20
# BP_WALL_MAX_LIVE=12
# BP_ARCHIVE_DIR=data/archive
# BP_PORT=8537              # wall port (CLI arg overrides); default 8537
# BP_INPUT_DEVICE=          # mic index or name substring; see --list-devices
# BP_FAL_MODEL=fal-ai/flux/schnell   # fal-ai/flux/dev follows the no-text prompt better
# BP_ENABLE_LISTENER=true   # false = wall only, no mic (tests/QA/no-mic host)
# Server-rendered /wall.png (the e-paper frame fetches this). Default is the
# Waveshare 13.3" Spectra 6 panel's 1600x1200; override for a different panel.
# BP_WALL_PNG_WIDTH=1600
# BP_WALL_PNG_HEIGHT=1200
# BP_WALL_FONT=             # path to a serif .ttf for captions (auto-discovers DejaVu/Georgia)
# BP_WALL_FONT_ITALIC=      # path to the italic serif .ttf
